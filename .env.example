# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=quiniela
POSTGRES_PASSWORD=quiniela_secret
POSTGRES_DB=quiniela

# Used by the FastAPI app directly (matches the db service hostname in Compose)
DATABASE_URL=postgresql+asyncpg://quiniela:quiniela_secret@db:5432/quiniela

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
